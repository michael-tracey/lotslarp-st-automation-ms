# Copy this file to .env and fill in your values.
# .env is gitignored and will never be committed.

# Google Sheets — the long ID from the spreadsheet URL
SPREADSHEET_ID=your_spreadsheet_id_here

# Path to the service account JSON key file (relative to utilities/ or absolute)
SERVICE_ACCOUNT_JSON=service_account.json

# Discord bot token (from the Discord Developer Portal)
BOT_TOKEN=your_bot_token_here

# Discord server (guild) ID — right-click the server icon → Copy Server ID
GUILD_ID=your_guild_id_here

# Optional: channel ID to use when running send_downtimes.py --dry-run 2
TEST_CHANNEL_ID=your_test_channel_id_here
